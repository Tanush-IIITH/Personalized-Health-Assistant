# --- Supabase Configuration ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_REPORTS_BUCKET=medical-reports
SUPABASE_OCR_REPORTS_TABLE=medical_reports

# --- Gemini / LLM Configuration ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-pro-preview

# Setup this flag only after verifying that your Gemini plan/contract 
# does not use customer health data for model training.
GEMINI_DATA_PROCESSING_APPROVED=false
